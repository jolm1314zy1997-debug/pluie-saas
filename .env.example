# QZT Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API URL (Python FastAPI server)
# Local dev: http://localhost:8000
# Production: your deployed backend URL (e.g. Railway, Render, etc.)
BACKEND_URL=http://localhost:8000

# aihubmix API Key (默认 API Key，前端客户未配置时使用)
# 部署到 Vercel 时，在 Vercel Dashboard -> Settings -> Environment Variables 中配置此值
AIHUBMIX_API_KEY=sk-your-default-api-key-here

# Supabase account login + per-salesperson cloud sync
# Create a Supabase project, run supabase/schema.sql, then fill these in.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
