# ===========================================================================
# Pluie - AI Lead Intelligence
# Copy this file to .env.local and fill in values for local dev.
# In Vercel: set the same keys in Settings -> Environment Variables.
# ===========================================================================

# ─── 必填: AI 网关 ─────────────────────────────────────────────────────────
# 所有 LLM 调用走 aihubmix（OpenAI 兼容）
# 注册并领 key: https://aihubmix.com
AIHUBMIX_API_KEY=sk-your-aihubmix-key

# ─── 必填: Supabase（账号 + 云同步）────────────────────────────────────────
# 1. https://supabase.com → New Project
# 2. SQL Editor 跑 supabase/schema.sql 整段
# 3. Settings → API 抄 URL + 一个 key 填这里
# !! NEXT_PUBLIC_SUPABASE_URL 必须形如 https://项目ID.supabase.co，不能带 /rest/v1/
# !! 新版 sb_publishable_xxx 和老版 anon JWT 都可以放 ANON_KEY 这个位置，代码兼容两种
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Service role / sb_secret_* 目前未被代码使用（全靠 RLS）。如果将来要做服务端
# admin 操作（绕过 RLS 的批量写），再填这里。
# SUPABASE_SERVICE_ROLE_KEY=

# ─── 可选: Google Places（地图获客 tab）────────────────────────────────────
# https://console.cloud.google.com → 启用 Places API (New) → 创建 API 密钥
# 不配则"地图获客"显示"未配置"友好提示，其他功能不受影响
GOOGLE_MAPS_API_KEY=

# ─── 可选: Cloudflare R2（物料库）─────────────────────────────────────────
# 完整开通步骤见 supabase/materials-setup.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pluie-materials
R2_PUBLIC_URL=
MATERIALS_UPLOAD_KEY=

# ─── 可选: 公司知识库（RAG）────────────────────────────────────────────────
# 默认值 = QZT 的 Apps Script + Worker（src/config/company.ts 里写死）
# 给其他公司用时改 src/config/company.ts 里的 COMPANY.kb.* 字段
# 或者用这些 env 覆盖（要求 Apps Script 接口和 QZT 同构）
QZT_KB_API_URL=
QZT_KB_API_KEY=
QZT_BOT_ASK_URL=

# ─── 可选: 品牌覆盖（NEXT_PUBLIC_* 构建时注入，部署后改要重新构建）────────
# 不填则用 src/config/brand.ts 里的 Pluie 默认值
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_TAGLINE=
NEXT_PUBLIC_BRAND_TAGLINE_ZH=
NEXT_PUBLIC_BRAND_LOGO=
NEXT_PUBLIC_BRAND_COPYRIGHT=
NEXT_PUBLIC_BRAND_META_TITLE=
NEXT_PUBLIC_BRAND_META_DESC=
NEXT_PUBLIC_ASSISTANT_URL=
NEXT_PUBLIC_ASSISTANT_LABEL=
NEXT_PUBLIC_BOT_UA=
